@model LibraryManagement.Models.Book

<h2>Create Book</h2>

<form asp-action="Create" method="post">

    <div>
        <label>Title</label>
        <input asp-for="Title" />
    </div>

    <div>
        <label>Author</label>
        <input asp-for="Author" />
    </div>

    <div>
        <label>Price</label>
        <input asp-for="Price" />
    </div>

    <button type="submit">Save</button>

</form>

<a asp-action="List">Back to List</a>