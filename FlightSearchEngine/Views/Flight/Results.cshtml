@model IEnumerable<object>

@{
    ViewData["Title"] = "Search Results";
}

<div class="container mt-5">

    <h2 class="text-center mb-4">Search Results</h2>

    @if (Model == null || !Model.Any())
    {
        <div class="alert alert-warning text-center">
            No results found.
        </div>
    }
    else
    {
        var firstItem = Model.First();

        // ----------------------------------------------------
        // FLIGHT ONLY RESULTS
        // ----------------------------------------------------
        if (firstItem is FlightSearchEngine.Models.FlightResult)
        {
            <table class="table table-bordered table-striped">
                <thead class="table-dark">
                    <tr>
                        <th>FlightId</th>
                        <th>FlightName</th>
                        <th>FlightType</th>
                        <th>Source</th>
                        <th>Destination</th>
                        <th>TotalCost</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (FlightSearchEngine.Models.FlightResult item in Model)
                    {
                        <tr>
                            <td>@item.FlightId</td>
                            <td>@item.FlightName</td>
                            <td>@item.FlightType</td>
                            <td>@item.Source</td>
                            <td>@item.Destination</td>
                            <td>@item.TotalCost</td>
                        </tr>
                    }
                </tbody>
            </table>
        }

        // ----------------------------------------------------
        // FLIGHT + HOTEL RESULTS
        // ----------------------------------------------------
        else if (firstItem is FlightSearchEngine.Models.FlightHotelResult)
        {
            <table class="table table-bordered table-striped">
                <thead class="table-dark">
                    <tr>
                        <th>FlightId</th>
                        <th>FlightName</th>
                        <th>Source</th>
                        <th>Destination</th>
                        <th>HotelName</th>
                        <th>TotalCost</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (FlightSearchEngine.Models.FlightHotelResult item in Model)
                    {
                        <tr>
                            <td>@item.FlightId</td>
                            <td>@item.FlightName</td>
                            <td>@item.Source</td>
                            <td>@item.Destination</td>
                            <td>@item.HotelName</td>
                            <td>@item.TotalCost</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    }

    <div class="text-center mt-4">
        <a asp-action="Index" asp-controller="Flight" class="btn btn-secondary">
            Back to Search
        </a>
    </div>

</div>