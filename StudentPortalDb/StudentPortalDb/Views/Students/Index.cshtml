@model IEnumerable<StudentPortalDb.Models.Student>
@using StudentPortalDb.Helpers

@{
    ViewData["Title"] = "Students";
    var q = (ViewBag.Query as string) ?? "";
}

<div class="container mt-4">

    <div class="card shadow-sm border-0">
        <div class="card-body">

            <!-- Header -->
            <div class="d-flex justify-content-between align-items-center mb-3">
                <div>
                    <h3 class="mb-0">Students</h3>
                    <small class="text-muted">CRUD + Live Search (AJAX)</small>
                </div>

                <a class="btn btn-primary" asp-action="Create">
                    + Add Student
                </a>
            </div>

            <!-- Search -->
            <div class="row g-2 mb-3">
                <div class="col-md-6">
                    <input id="q"
                           class="form-control"
                           placeholder="Search name or email..."
                           value="@q" />
                </div>
                <div class="col-auto">
                    <button id="btnSearch" class="btn btn-outline-primary">
                        Search
                    </button>
                </div>
            </div>

            <div id="liveBox" class="small text-muted mb-2"></div>

            <!-- Table -->
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Id</th>
                            <th>Name</th>
                            <th>Email</th>
                            <th>Status</th>
                            <th style="width:180px">Actions</th>
                        </tr>
                    </thead>
                    <tbody id="tblBody">
                        @foreach (var s in Model)
                        {
                            <tr>
                                <td>@s.StudentId</td>
                                <td class="fw-semibold">@s.FullName</td>
                                <td>@s.MaskedEmail</td>
                                <td>
                                    <span class="badge @(s.Status == "Active" ? "bg-success" : "bg-secondary")">
                                        @s.Status
                                    </span>
                                </td>
                                <td>
                                    <a class="btn btn-sm btn-outline-secondary"
                                       asp-action="Edit"
                                       asp-route-id="@s.StudentId">Edit</a>

                                    <a class="btn btn-sm btn-outline-danger"
                                       asp-action="Delete"
                                       asp-route-id="@s.StudentId">Delete</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

        </div>
    </div>

</div>

<div class="mt-3">

    <a class="btn btn-secondary"
       asp-action="Index"
       asp-route-page="@(ViewBag.Page - 1)">
        Previous
    </a>

    <span class="mx-2">
        Page @ViewBag.Page
    </span>

    <a class="btn btn-secondary"
       asp-action="Index"
       asp-route-page="@(ViewBag.Page + 1)">
        Next
    </a>

</div>

@section Scripts {
    <script>
        const qEl = document.getElementById("q");
        const box = document.getElementById("liveBox");
        const tbody = document.getElementById("tblBody");
        const btn = document.getElementById("btnSearch");

        let t = null;


        function renderRows(items){
            if(!items || items.length === 0){
                tbody.innerHTML =
                  `<tr><td colspan="5" class="text-center text-muted py-3">
                      No results found
                   </td></tr>`;
                return;
            }

            tbody.innerHTML = items.map(s => `
                <tr>
                    <td>${s.studentId}</td>
                    <td class="fw-semibold">${s.fullName}</td>
                    <td>${maskEmail(s.email)}</td>
                    <td>
                        <span class="badge ${
                            s.status === "Active"
                            ? "bg-success"
                            : "bg-secondary"
                        }">
                            ${s.status}
                        </span>
                    </td>
                    <td>
                        <a class="btn btn-sm btn-outline-secondary"
                           href="/Students/Edit/${s.studentId}">
                           Edit
                        </a>
                        <a class="btn btn-sm btn-outline-danger"
                           href="/Students/Delete/${s.studentId}">
                           Delete
                        </a>
                    </td>
                </tr>
            `).join("");
        }

            async function liveSearch(){
            const q = qEl.value.trim();

            box.innerHTML =
                `<span class="spinner-border spinner-border-sm"></span>
                 Searching...`;

            const res =
              await fetch(`/Students/Search?q=${encodeURIComponent(q)}`);

            const data = await res.json();

            if(q.length === 0){
                box.textContent = "";
            } else {
                box.textContent = `Found: ${data.length}`;
            }

            renderRows(data);
        }

        qEl.addEventListener("keyup", () => {
            clearTimeout(t);
            t = setTimeout(liveSearch, 300);
        });

        btn.addEventListener("click", liveSearch);
    </script>
}